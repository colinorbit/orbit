{
  "name": "orbit-advancement-api",
  "version": "1.4.0",
  "description": "Orbit Advancement \u2014 AI Fundraising Intelligence Platform API v1.4.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc --build",
    "tsc": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:ci": "jest --ci --coverage --forceExit",
    "lint": "eslint src/ --ext .js,.ts",
    "db:migrate": "node src/migrations/run.js",
    "db:seed": "node src/migrations/seed.js",
    "docker:build": "docker build -t orbit-api:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "backup": "docker compose --profile backup up backup",
    "test:unit": "jest --forceExit --detectOpenHandles --testPathIgnorePatterns=e2e",
    "test:e2e": "jest --forceExit --detectOpenHandles --testPathPattern=e2e",
    "test:coverage": "jest --ci --coverage --forceExit --testPathIgnorePatterns=e2e",
    "migrate": "for f in src/migrations/*.sql; do echo \"Running $f...\"; psql $DATABASE_URL -f $f; done"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@sendgrid/mail": "^8.1.1",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "docusign-esign": "^6.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsforce": "^1.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "stripe": "^14.14.0",
    "twilio": "^5.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0",
    "jest-junit": "^16.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/e2e/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "coverage",
          "outputName": "junit.xml"
        }
      ]
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/migrations/**",
      "!src/index.ts"
    ],
    "testTimeout": 30000
  }
}