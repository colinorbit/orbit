# ══════════════════════════════════════════════════════════════════════════════
# ORBIT PLATFORM — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# URL where THIS backend is reachable (used in emails, webhooks)
API_URL=http://localhost:3001
# Frontend URL for CORS allow-list
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/orbit
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis (for caching + rate limiting) ──────────────────────────────────────
# Local dev: start with `docker run -p 6379:6379 redis`
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_RANDOM_CHARS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
# Comma-separated emails that can access superadmin portal
SUPERADMIN_EMAILS=you@yourdomain.com

# ─── Encryption (CRM credentials stored encrypted at rest) ────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX

# ─── AI — Claude (Anthropic) ──────────────────────────────────────────────────
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=1000
ENABLE_AI_AGENTS=true

# ─── CRM Integrations ─────────────────────────────────────────────────────────

# Salesforce (NPSP / EDA)
# Setup: https://help.salesforce.com/s/articleView?id=sf.connected_app_create.htm
ENABLE_SALESFORCE=false
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=59.0

# Blackbaud Raiser's Edge NXT
# Setup: https://developer.blackbaud.com/skyapi/apis/renxt
RENXT_SUBSCRIPTION_KEY=
RENXT_CLIENT_ID=
RENXT_CLIENT_SECRET=
RENXT_WEBHOOK_SECRET=

# HubSpot
# Setup: https://developers.hubspot.com/docs/api/private-apps
HS_TOKEN=
HS_PORTAL_ID=
HS_WEBHOOK_SECRET=

# ─── Email — SendGrid ─────────────────────────────────────────────────────────
# Setup: https://app.sendgrid.com/settings/api_keys
ENABLE_EMAIL=false
SENDGRID_API_KEY=SG.YOUR_KEY_HERE
SENDGRID_FROM_EMAIL=giving@youruniversity.edu
SENDGRID_FROM_NAME=Greenfield University Giving
# Dynamic template IDs from your SendGrid account:
SENDGRID_TMPL_WELCOME=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_GIFT_ASK=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_GIFT_RECEIPT=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_PLEDGE_CONFIRM=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_PLEDGE_REMINDER=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_CAMPAIGN_LAUNCH=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_IMPACT_UPDATE=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_STEWARDSHIP=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_TMPL_LEGACY_INTRO=d-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── SMS — Twilio ─────────────────────────────────────────────────────────────
# Setup: https://console.twilio.com
ENABLE_SMS=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15005550006
# Optional: use a messaging service SID instead of a number
TWILIO_MESSAGING_SERVICE_SID=

# ─── e-Signature — DocuSign ───────────────────────────────────────────────────
# Setup: https://developers.docusign.com/platform/auth/jwt/
ENABLE_DOCUSIGN=false
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=https://account-d.docusign.com
DOCUSIGN_PRIVATE_KEY=   # Base64-encoded RSA private key
DOCUSIGN_CONNECT_SECRET=
# Template IDs for pledge agreements / gift letters:
DOCUSIGN_TMPL_SINGLE_GIFT=
DOCUSIGN_TMPL_MULTI_YEAR_PLEDGE=
DOCUSIGN_TMPL_PLANNED_GIFT=

# ─── Billing — Stripe ─────────────────────────────────────────────────────────
# Setup: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
# Create these price IDs in your Stripe dashboard:
STRIPE_PRICE_STARTER=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_GROWTH=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ENTERPRISE=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Logging + Monitoring ─────────────────────────────────────────────────────
LOG_LEVEL=info
# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://...@sentry.io/...

# ─── Background Jobs ──────────────────────────────────────────────────────────
# Cron expression for nightly metric snapshots (default: 2am daily)
METRIC_SNAPSHOT_CRON=0 2 * * *
