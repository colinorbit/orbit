# ─────────────────────────────────────────────────────────────────────────
# Orbit Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# See docs/ENV.md for full documentation.
# ─────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit_dev_password
POSTGRES_DB=orbit
POSTGRES_PORT=5432
DATABASE_URL=postgresql://orbit:orbit_dev_password@localhost:5432/orbit

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=orbit_redis_dev
REDIS_URL=redis://:orbit_redis_dev@localhost:6379

# ── Auth (generate with: openssl rand -hex 64) ───────────────────────────
JWT_SECRET=replace_with_64_char_random_hex_string
# generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_32_byte_hex_string

# ── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api...
ANTHROPIC_MODEL=claude-opus-4-5

# ── SendGrid ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...

# ── Twilio ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# ── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── DocuSign ─────────────────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=

# ── Salesforce ───────────────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com
