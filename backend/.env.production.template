# ═══════════════════════════════════════════════════════════════════
#  ORBIT ADVANCEMENT — PRODUCTION ENVIRONMENT CONFIG
#  Copy this file to .env and fill in ALL values before deploying.
#  NEVER commit .env to git. Add it to .gitignore immediately.
# ═══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://app.orbit.ai          # Your deployed frontend URL

# ── Security (GENERATE THESE — do not use defaults) ─────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=8h
SESSION_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY   # For AES-256 field encryption

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://orbit_user:STRONG_PASSWORD@localhost:5432/orbit_prod
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis (session store, rate limiting, job queues) ─────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false   # Set true on Railway/Render/Heroku

# ── AI — Anthropic (NEVER expose to client) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS_DEFAULT=900
AI_DAILY_TOKEN_BUDGET=2000000   # Per-org daily token cap (2M tokens ≈ $6/day at Sonnet pricing)

# ── Email (SendGrid) ─────────────────────────────────────────────────
SENDGRID_API_KEY=SG.REPLACE_WITH_REAL_KEY
FROM_EMAIL=noreply@orbit.ai
FROM_NAME=Orbit Advancement

# ── SMS (Twilio) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_WITH_REAL_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CRM Integrations ─────────────────────────────────────────────────
# Salesforce (OAuth2 — one set per tenant stored encrypted in DB)
SALESFORCE_CLIENT_ID=REPLACE
SALESFORCE_CLIENT_SECRET=REPLACE
SALESFORCE_REDIRECT_URI=https://api.orbit.ai/api/v1/integrations/salesforce/callback

# Blackbaud RE NXT
BLACKBAUD_CLIENT_ID=REPLACE
BLACKBAUD_CLIENT_SECRET=REPLACE
BLACKBAUD_SUBSCRIPTION_KEY=REPLACE
BLACKBAUD_REDIRECT_URI=https://api.orbit.ai/api/v1/integrations/blackbaud/callback

# HubSpot
HUBSPOT_CLIENT_ID=REPLACE
HUBSPOT_CLIENT_SECRET=REPLACE
HUBSPOT_REDIRECT_URI=https://api.orbit.ai/api/v1/integrations/hubspot/callback

# ── Payments (Stripe) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE    # From Stripe dashboard → webhooks

# Stripe Price IDs — one per plan tier (copy from Stripe Products dashboard)
STRIPE_PRICE_STARTER=price_REPLACE_STARTER
STRIPE_PRICE_GROWTH=price_REPLACE_GROWTH
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ENTERPRISE

# SendGrid event webhook — add to env for open/click/bounce tracking
SENDGRID_FROM_EMAIL=noreply@orbit.ai
SENDGRID_FROM_NAME=Orbit Advancement
# Template IDs (from SendGrid Dynamic Templates dashboard)
SENDGRID_TMPL_WELCOME=d-REPLACE
SENDGRID_TMPL_IMPACT_UPDATE=d-REPLACE
SENDGRID_TMPL_GIFT_ASK=d-REPLACE
SENDGRID_TMPL_PLEDGE_CONFIRM=d-REPLACE
SENDGRID_TMPL_PLEDGE_REMINDER=d-REPLACE
SENDGRID_TMPL_GIFT_RECEIPT=d-REPLACE

# Public API URL (used in webhook callbacks, email links)
API_URL=https://api.orbit.ai
CLIENT_URL=https://app.orbit.ai

# Email/SMS feature flags (set false in staging to prevent real sends)
ENABLE_EMAIL=true
ENABLE_SMS=true

# ── Matching Gifts ───────────────────────────────────────────────────
BENEVITY_API_KEY=REPLACE
YOURCAUSE_API_KEY=REPLACE
DOUBLE_THE_DONATION_KEY=REPLACE

# ── Monitoring & Logging ─────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
SENTRY_DSN=https://REPLACE@o0.ingest.sentry.io/0   # Error tracking
DATADOG_API_KEY=REPLACE   # Optional: APM + infrastructure metrics

# ── Feature Flags ────────────────────────────────────────────────────
ENABLE_SMS=true
ENABLE_MATCHING_GIFTS=true
ENABLE_PLANNED_GIVING=true
ENABLE_LEGACY_WILL_BUILDER=true
ENABLE_AI_BULK_PERSONALIZE=true
ENABLE_SIGNAL_INTELLIGENCE=true
DEMO_MODE=false   # Set true to allow demo login bypass (dev/staging only)

# ── File Storage (AWS S3 for impact reports, PDFs) ───────────────────
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=us-east-1
S3_BUCKET_NAME=orbit-prod-documents

# ── Rate Limiting (customize per plan tier) ──────────────────────────
RATE_LIMIT_API_WINDOW_MS=900000      # 15 min
RATE_LIMIT_API_MAX=300               # Requests per window (general)
RATE_LIMIT_AUTH_MAX=20               # Auth endpoints
RATE_LIMIT_AI_MAX=60                 # AI generation per user per 15min
RATE_LIMIT_AI_BULK_HOURLY=5          # Bulk email generation per hour

# ── Super Admin ────────────────────────────────────────────────────────────────
SUPERADMIN_EMAILS=admin@orbit.ai,ops@orbit.ai
# Comma-separated list of emails allowed to use /auth/superadmin-login
# These users must also exist in the DB with role='superadmin'

# ── Encryption (for integration config storage) ────────────────────────────────
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
# Generate: openssl rand -hex 32
